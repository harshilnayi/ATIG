# Emerging Threats Open Rules - ATIG
# Download full set from: https://rules.emergingthreats.net/open/

alert tcp $EXTERNAL_NET any -> $HOME_NET 80 (msg:"ET WEB_SERVER SQL Injection attempt UNION SELECT"; flow:to_server,established; content:"UNION"; nocase; content:"SELECT"; nocase; distance:0; within:15; sid:2000001; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 22 (msg:"ET SCAN SSH Brute Force Login Attempt"; flow:to_server,established; content:"SSH"; sid:2000002; rev:1;)
alert udp $EXTERNAL_NET any -> $HOME_NET 53 (msg:"ET DNS Query for Known Malicious Domain"; content:"|01 00 00 01|"; depth:10; sid:2000003; rev:1;)
alert tcp $HOME_NET any -> $EXTERNAL_NET 4444 (msg:"ET POLICY Possible Metasploit Default Port"; flow:to_server; sid:2000004; rev:1;)
alert tcp $HOME_NET any -> $EXTERNAL_NET any (msg:"ET INFO Outgoing Connection to Known C2 Server"; content:"POST"; http_method; content:"/beacon"; http_uri; sid:2000005; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 3389 (msg:"ET SCAN RDP Brute Force Attempt"; flow:to_server; sid:2000006; rev:1;)
alert tcp $HOME_NET any -> $EXTERNAL_NET 6667 (msg:"ET POLICY IRC Outgoing Connection"; flow:to_server; sid:2000007; rev:1;)
alert udp $HOME_NET any -> $EXTERNAL_NET 123 (msg:"ET NTP Amplification Attack Detected"; dsize:>468; sid:2000008; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 445 (msg:"ET SMB Windows Exploit Attempt"; content:"|FF|SMB"; depth:4; content:"|04 D1|"; offset:14; depth:2; sid:2000009; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 8080 (msg:"ET PROXY Possible Open Proxy"; flow:to_server,established; content:"CONNECT"; http_method; sid:2000010; rev:1;)
