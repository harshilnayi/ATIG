# Emerging Threats Open Rules - ATIG Enhanced
# Comprehensive detection rules for network intrusion

# === SQL INJECTION ATTACKS ===
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"ET WEB_SERVER SQL Injection UNION SELECT"; flow:to_server,established; content:"UNION"; nocase; content:"SELECT"; nocase; distance:0; within:15; sid:2000001; rev:2;)
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"ET WEB_SERVER SQL Injection OR 1=1 Attempt"; flow:to_server,established; content:"OR"; nocase; content:"1=1"; distance:0; within:10; sid:2000011; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"ET WEB_SERVER SQL Injection DROP TABLE"; flow:to_server,established; content:"DROP"; nocase; content:"TABLE"; nocase; distance:0; within:15; sid:2000012; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"ET WEB_SERVER SQL Injection Comment Injection"; flow:to_server,established; content:"--"; content:"OR"; nocase; distance:0; sid:2000013; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"ET WEB_SERVER SQL Injection CONCAT Exploit"; flow:to_server,established; content:"CONCAT"; nocase; content:"(" ; sid:2000014; rev:1;)

# === XSS ATTACKS ===
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"ET WEB_SERVER Cross-Site Scripting Script Tag"; flow:to_server,established; content:"<script>"; nocase; sid:2000020; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"ET WEB_SERVER Cross-Site Scripting Event Handler"; flow:to_server,established; content:"onerror="; nocase; sid:2000021; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"ET WEB_SERVER Cross-Site Scripting JavaScript Protocol"; flow:to_server,established; content:"javascript:"; nocase; sid:2000022; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"ET WEB_SERVER Cross-Site Scripting Eval Function"; flow:to_server,established; content:"eval("; nocase; sid:2000023; rev:1;)

# === PATH TRAVERSAL ===
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"ET WEB_SERVER Path Traversal Attempt"; flow:to_server,established; content:"../"; sid:2000030; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"ET WEB_SERVER Path Traversal Double Encoding"; flow:to_server,established; content:"..%2f"; nocase; sid:2000031; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"ET WEB_SERVER Path Traversal /etc/passwd"; flow:to_server,established; content:"/etc/passwd"; sid:2000032; rev:1;)

# === COMMAND INJECTION ===
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"ET WEB_SERVER Command Injection Pipe"; flow:to_server,established; content:"|cat"; nocase; sid:2000040; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"ET WEB_SERVER Command Injection Backtick"; flow:to_server,established; content:"`"; content:"$("; distance:0; within:5; sid:2000041; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"ET WEB_SERVER Command Injection wget"; flow:to_server,established; content:"wget "; nocase; sid:2000042; rev:1;)

# === BUFFER OVERFLOW ATTEMPTS ===
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"ET EXPLOIT Potential Buffer Overflow - Large Payload"; flow:to_server; dsize:>4096; sid:2000050; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"ET EXPLOIT NOP Slide Detection"; flow:to_server; content:"|90 90 90 90 90 90 90 90|"; sid:2000051; rev:1;)

# === MALWARE & C2 COMMUNICATION ===
alert tcp $HOME_NET any -> $EXTERNAL_NET 4444 (msg:"ET POLICY Possible Metasploit Default Port"; flow:to_server; sid:2000004; rev:2;)
alert tcp $HOME_NET any -> $EXTERNAL_NET any (msg:"ET INFO Outgoing Connection to Known C2 Server"; content:"POST"; http_method; content:"/beacon"; http_uri; sid:2000005; rev:2;)
alert tcp $HOME_NET any -> $EXTERNAL_NET any (msg:"ET POLICY Cobalt Strike Beacon Pattern"; flow:to_server; content:"|00 01 02 03 04 05 06 07|"; sid:2000055; rev:1;)
alert tcp $HOME_NET any -> $EXTERNAL_NET any (msg:"ET POLICY Suspicious User Agent - Botnet"; flow:to_server; content:"Mozilla/4.0"; distance:0; content:"; .NET CLR"; sid:2000056; rev:1;)

# === SCAN & RECONNAISSANCE ===
alert tcp $EXTERNAL_NET any -> $HOME_NET 22 (msg:"ET SCAN SSH Brute Force Login Attempt"; flow:to_server,established; content:"SSH"; sid:2000002; rev:2;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 3389 (msg:"ET SCAN RDP Brute Force Attempt"; flow:to_server; sid:2000006; rev:2;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 23 (msg:"ET SCAN Telnet Brute Force Attempt"; flow:to_server; sid:2000060; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 21 (msg:"ET SCAN FTP Brute Force Attempt"; flow:to_server; content:"USER"; sid:2000061; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 3306 (msg:"ET SCAN MySQL Brute Force Attempt"; flow:to_server; sid:2000062; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 5432 (msg:"ET SCAN PostgreSQL Brute Force Attempt"; flow:to_server; sid:2000063; rev:1;)

# === DNS ATTACKS ===
alert udp $EXTERNAL_NET any -> $HOME_NET 53 (msg:"ET DNS Query for Known Malicious Domain"; content:"|01 00 00 01|"; depth:10; sid:2000003; rev:2;)
alert udp $EXTERNAL_NET any -> $HOME_NET 53 (msg:"ET DNS Large Response Possible DGA"; dsize:>512; sid:2000070; rev:1;)
alert udp $HOME_NET any -> $EXTERNAL_NET 53 (msg:"ET DNS NXDOMAIN Response High Rate - Possible DGA"; dsize:>100; sid:2000071; rev:1;)

# === PROPRIETARY PROTOCOLS ===
alert tcp $HOME_NET any -> $EXTERNAL_NET 6667 (msg:"ET POLICY IRC Outgoing Connection"; flow:to_server; sid:2000007; rev:2;)
alert tcp $HOME_NET any -> $EXTERNAL_NET 6666 (msg:"ET POLICY Alt IRC Outgoing Connection"; flow:to_server; sid:2000072; rev:1;)
alert tcp $HOME_NET any -> $EXTERNAL_NET 1337 (msg:"ET POLICY Possible Reverse Shell Port 1337"; flow:to_server; sid:2000073; rev:1;)

# === SMB & NETWORK EXPLOITS ===
alert tcp $EXTERNAL_NET any -> $HOME_NET 445 (msg:"ET SMB Windows Exploit Attempt - EternalBlue"; content:"|FF|SMB"; depth:4; content:"|04 D1|"; offset:14; within:2; sid:2000009; rev:2;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 445 (msg:"ET SMB NTLM Authentication Attempt"; content:"NTLMSSP"; sid:2000080; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 139 (msg:"ET SMB NetBIOS Session Request"; sid:2000081; rev:1;)

# === WEB APPLICATION ATTACKS ===
alert tcp $EXTERNAL_NET any -> $HOME_NET 80 (msg:"ET WEB_SERVER Directory Traversal /admin"; flow:to_server,established; content:"/admin"; content:"../"; distance:0; sid:2000090; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 80 (msg:"ET WEB_SERVER Admin Panel Access Attempt"; flow:to_server,established; content:"/admin"; content:"/login"; distance:0; sid:2000091; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 80 (msg:"ET WEB_SERVER WordPress WP-Content Access"; flow:to_server,established; content:"/wp-content"; sid:2000092; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 80 (msg:"ET WEB_SERVER PHP File Include Attempt"; flow:to_server,established; content:"php://"; nocase; sid:2000093; rev:1;)

# === NTP & AMPLIFICATION ATTACKS ===
alert udp $HOME_NET any -> $EXTERNAL_NET 123 (msg:"ET NTP Amplification Attack Detected"; dsize:>468; sid:2000008; rev:2;)
alert udp $EXTERNAL_NET any -> $HOME_NET 53 (msg:"ET DNS Amplification Attack"; dsize:>512; sid:2000094; rev:1;)

# === PROXY & RELAY ATTACKS ===
alert tcp $EXTERNAL_NET any -> $HOME_NET 8080 (msg:"ET PROXY Possible Open Proxy"; flow:to_server,established; content:"CONNECT"; http_method; sid:2000010; rev:2;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 1080 (msg:"ET PROXY SOCKS Proxy Detected"; flow:to_server; sid:2000095; rev:1;)

# === LATERAL MOVEMENT ===
alert tcp $HOME_NET any -> $HOME_NET 445 (msg:"ET INTRUSION SMB Lateral Movement"; flow:to_server; content:"|FF|SMB"; sid:2000100; rev:1;)
alert tcp $HOME_NET any -> $HOME_NET 5985 (msg:"ET INTRUSION PowerShell Remoting WinRM"; flow:to_server; sid:2000101; rev:1;)
alert tcp $HOME_NET any -> $HOME_NET 5986 (msg:"ET INTRUSION PowerShell Remoting WinRM HTTPS"; flow:to_server; sid:2000102; rev:1;)

# === DATA EXFILTRATION ===
alert tcp $HOME_NET any -> $EXTERNAL_NET any (msg:"ET DATA_EXFIL Large Outbound Transfer"; flow:to_server,established; dsize:>100000; sid:2000110; rev:1;)
alert tcp $HOME_NET any -> $EXTERNAL_NET 21 (msg:"ET DATA_EXFIL FTP Data Transfer"; flow:to_server,established; sid:2000111; rev:1;)
alert tcp $HOME_NET any -> $EXTERNAL_NET 22 (msg:"ET DATA_EXFIL SFTP Data Transfer"; flow:to_server,established; sid:2000112; rev:1;)
